# PawTrack Backend - Environment Configuration Template
# 
# Copy this file to .env and fill in the actual values for your environment.
# NEVER commit .env to version control.

# PostgreSQL Database Connection String
# Format: postgresql://username:password@host:port/database
# Example: postgresql://pawtrack_admin:password123@localhost:5432/pawtrack_db
DATABASE_URL=postgresql://pawtrack_admin:YOUR_DB_PASSWORD@localhost/pawtrack_db

# JWT Secret Key for signing tokens
# IMPORTANT: Use a cryptographically secure random string in production.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Minimum 32 characters recommended.
SECRET_KEY=your_secure_random_secret_key_here_minimum_32_chars

# JWT Algorithm (typically HS256)
# Options: HS256, HS384, HS512, RS256, RS384, RS512
ALGORITHM=HS256

# JWT Token Expiration Time in Minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Environment (development, staging, production)
ENVIRONMENT=development

# Disable rate limits during local automated testing. Use true in production.
RATE_LIMIT_ENABLED=true

# Optional. Set this to a persistent disk path in production, for example:
# UPLOADS_DIR=/var/data/pawtrack/uploads
UPLOADS_DIR=
